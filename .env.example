# GolfAlign local environment example
# Copy this file to .env.local before connecting real Google APIs.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin login. Production must set these explicitly.
ADMIN_LOGIN_ID=
ADMIN_PASSWORD=

# Google account login.
# Add this redirect URI in Google Cloud Console:
# http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Drive folder provided for MVP DB/media testing.
GOOGLE_DRIVE_ROOT_FOLDER_ID=1yn75-KuQ1GRR6GqnRZ2n8t5u2t83AEZO
GOOGLE_DRIVE_SHEET_FOLDER_ID=1ixM9gVRDFSYkNIuqhbbuPdxJ0UTodPUP

# Create or select a spreadsheet in the sheet folder, then paste its ID here.
GOOGLE_SHEETS_SPREADSHEET_ID=1Y1dAKoggA1Ae-DSZQZf2FilxZE7VOJod-n-lechyJ0M

# Service account credentials for server-side Google Sheets / Drive API calls.
# Share the spreadsheet and required Drive folders with GOOGLE_CLIENT_EMAIL as editor.
# When entering GOOGLE_PRIVATE_KEY in Vercel, replace line breaks with \n.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# NAS backup is optional during MVP.
NAS_BACKUP_ENABLED=false
NAS_BACKUP_BASE_PATH=
